# Shared middleware
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
REDIS_HOST=localhost
REDIS_PORT=6379
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces

# Shared database defaults
DATABASE_USERNAME=admin
DATABASE_PASSWORD=admin

# Per-service database URLs
IDENTITY_DATABASE_URL=jdbc:postgresql://localhost:5433/umevent_identity
EVENT_DATABASE_URL=jdbc:postgresql://localhost:5433/umevent_event
MINUTES_DATABASE_URL=jdbc:postgresql://localhost:5433/umevent_minutes
PLANNING_DATABASE_URL=jdbc:postgresql://localhost:5433/umevent_planning
ANALYTICS_DATABASE_URL=jdbc:postgresql://localhost:5433/umevent_analytics

# Integration service
GOOGLE_DRIVE_FOLDER_ID=demo-folder
GOOGLE_GMAIL_QUERY=subject:(event OR meeting)

# Notification service
NOTIFICATION_RETRY_MAX_ATTEMPTS=5
NOTIFICATION_RETRY_BACKOFF_MS=1000
