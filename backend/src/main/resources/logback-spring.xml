<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <property name="APP_NAME" value="um-event-management"/>
    <property name="LOG_PATH" value="logs"/>

    <property name="COMMON_PATTERN"
              value="%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level [%X{traceId:-na}] %logger{36} - %msg%n"/>
    <property name="DIGEST_PATTERN"
              value="%d{yyyy-MM-dd HH:mm:ss.SSS} [%X{traceId:-na}] %msg%n"/>

    <appender name="CONSOLE_COMMON" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>${COMMON_PATTERN}</pattern>
        </encoder>
    </appender>

    <appender name="CONSOLE_DIGEST" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>${DIGEST_PATTERN}</pattern>
        </encoder>
    </appender>

    <appender name="FILE_COMMON" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_PATH}/${APP_NAME}-common.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_PATH}/archive/${APP_NAME}-common.%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
            <maxFileSize>10MB</maxFileSize>
            <maxHistory>14</maxHistory>
            <totalSizeCap>1GB</totalSizeCap>
        </rollingPolicy>
        <encoder>
            <pattern>${COMMON_PATTERN}</pattern>
        </encoder>
    </appender>

    <appender name="FILE_DIGEST" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_PATH}/${APP_NAME}-digest.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_PATH}/archive/${APP_NAME}-digest.%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
            <maxFileSize>10MB</maxFileSize>
            <maxHistory>30</maxHistory>
            <totalSizeCap>1GB</totalSizeCap>
        </rollingPolicy>
        <encoder>
            <pattern>${DIGEST_PATTERN}</pattern>
        </encoder>
    </appender>

    <!-- Digest logger for compact status/code style entries -->
    <logger name="DIGEST" level="INFO" additivity="false">
        <appender-ref ref="CONSOLE_DIGEST"/>
        <appender-ref ref="FILE_DIGEST"/>
    </logger>

    <!-- Reduce noisy frameworks while keeping useful diagnostics -->
    <logger name="org.springframework.web" level="INFO"/>
    <logger name="org.springframework.security" level="INFO"/>
    <logger name="org.hibernate" level="WARN"/>

    <root level="INFO">
        <appender-ref ref="CONSOLE_COMMON"/>
        <appender-ref ref="FILE_COMMON"/>
    </root>

</configuration>